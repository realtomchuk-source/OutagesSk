@echo off
echo ========================================================
echo   Запуск автоматичного тестування парсера (Безкінечно)
echo ========================================================
echo Цей скрипт запускатиме парсер кожні 15 хвилин.
echo Щоб зупинити його - просто закрийте це чорне вікно.
echo.

set loopcount=0

:loop
set /a loopcount+=1
echo [%loopcount%] Запуск парсера: %time%
python collector.py
python formatter.py

echo.
echo Очікування 15 хвилин до наступного запуску...
timeout /t 900
goto loop
